# MockIT Environment Variables
# Copy this file to .env and fill in real values

# Django
SECRET_KEY=change-me-to-a-real-secret-key

# 100ms Video (HMS)
HMS_APP_ACCESS_KEY=your-hms-access-key
HMS_APP_SECRET=your-hms-app-secret
HMS_TEMPLATE_ID=your-hms-template-id

# Resend Email
RESEND_API_KEY=your-resend-api-key

# PostgreSQL Database
DB_NAME=mockit
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
